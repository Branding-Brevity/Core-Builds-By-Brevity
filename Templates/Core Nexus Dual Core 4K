            "description": "\u2394 {addon.name::smallcaps}{service.shortName::exists[\" [{service.shortName}]\"||\"\"]} \u00b7 {stream.type::exists[\"{stream.type::smallcaps} \u00b7 \"||\"\"]}{service.cached::istrue[\"\u25b6 I\u0274s\u1d1b\u1d00\u0274\u1d1b\"||\"\u2726 D\u1d0f\u1d21\u0274\u029f\u1d0f\u1d00\u1d05\"]}{stream.seeders::>0[\" \u00b7 \u25a4 {stream.seeders} P\u1d07\u1d07\u0280s\"||\"\"]}{tools.newLine}\u25b9 {stream.title::exists[\"{stream.title}\"||\"U\u0274\u1d0b\u0274\u1d0f\u1d21\u0274 T\u026a\u1d1b\u029f\u1d07\"]}{stream.season::exists[\" - S{stream.season}\"||\"\"]}{stream.episode::exists[\" E{stream.episode}\"||\"\"]}{tools.newLine}\u25a3 {stream.encode::exists[\"{stream.encode::replace('HEVC','\u029c\u1d07\u1d20\u1d04')::replace('AVC','\u1d00\u1d20\u1d04')::replace('AV1','\u1d00\u1d201')::smallcaps} \"||\"\"]}{stream.visualTags::exists[\"{stream.visualTags::join(', ')::replace('SDR','SDR \u2713')::replace('HDR','\u26a0 HDR')::replace('DV','\u26a0 DV')::replace('STANDARD','S\u1d1b\u1d00\u0274\u1d05\u1d00\u0280\u1d05')::replace('Standard','S\u1d1b\u1d00\u0274\u1d05\u1d00\u0280\u1d05')::smallcaps}\"||\"S\u1d1b\u1d00\u0274\u1d05\u1d00\u0280\u1d05\"]}{stream.bitrate::exists[\" ({stream.bitrate::sbitrate::replace('MBPS','\u1d0d\u0299\u1d18s')::replace('Mbps','\u1d0d\u0299\u1d18s')::replace('KBPS','\u1d0b\u0299\u1d18s')::replace('Kbps','\u1d0b\u0299\u1d18s')::smallcaps})\"||\"\"]} \u00b7 \u25c8 {stream.size::>0[\"{stream.size::sbytes::smallcaps}\"||\"U\u0274\u1d0b\"]}{stream.seasonPack::istrue[\" \u229e\"||\"\"]}{tools.newLine}\u2756 {stream.seadex::istrue[\"\ud83d\udc51 S\u1d07\u1d00D\u1d07x \u00b7 \"||\"\"]}{stream.releaseGroup::exists[\"{stream.releaseGroup::smallcaps}\"||\"U\u0274\u1d0b\"]} \u00b7 {stream.languages::~English[\"\u2691 E\u0274\u0262\u029f\u026as\u029c \u00b7 \"||\"\"]}{stream.languages::~Dual[\"\u2691 D\u1d1c\u1d00\u029f A\u1d1c\u1d05\u026a\u1d0f \u00b7 \"||\"\"]}{stream.languages::~Dubbed[\"\u2691 D\u1d1c\u0299\u0299\u1d07\u1d05 \u00b7