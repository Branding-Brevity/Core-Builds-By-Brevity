    "formatter": {
      "id": "tamtaro",
      "definitions": {
        "overrides": {
          "tamtaro": {
            "name": "{service.shortName::exists[\"[{service.shortName}] \"||\"\"]}{stream.resolution::exists[\"{stream.resolution::replace('2160p','4K')::replace('1440p','2K')}\"||\"U\u0274\u1d0b\u0274\u1d0f\u1d21\u0274\"]} \u00b7 {stream.quality::exists[\"{stream.quality::replace('BluRay REMUX','R\u1d07\u1d0d\u1d1cx')::replace('BLURAY REMUX','R\u1d07\u1d0d\u1d1cx')::replace('Bluray Remux','R\u1d07\u1d0d\u1d1cx')::replace('BluRay Remux','R\u1d07\u1d0d\u1d1cx')::replace('BluRay','B\u029f\u1d1cR\u1d00\u028f')::replace('BLURAY','B\u029f\u1d1cR\u1d00\u028f')::replace('WEB-DL','W\u1d07\u0299-DL')::replace('Web-dl','W\u1d07\u0299-DL')::replace('WEBRip','W\u1d07\u0299R\u026a\u1d18')::replace('Webrip','W\u1d07\u0299R\u026a\u1d18')::smallcaps}\"||\"S\u1d1b\u1d00\u0274\u1d05\u1d00\u0280\u1d05\"]} {stream.editions::exists[\" \u2702\ufe0f {stream.editions::join(', ')::smallcaps}\"||\"\"]}{stream.filename::~Boutique[\" \u2702\ufe0f \u0299\u1d0f\u1d1c\u1d1b\u026aQ\u1d1c\u1d07\"||\"\"]}{stream.filename::~Despecialized[\" \u2702\ufe0f \u1d05\u1d07\ua731\u1d18\u1d07\u1d04\u026a\u1d00\u029f\u026a\u1d22\u1d07\u1d05\"||\"\"]}{stream.filename::~Final.Cut[\" \u2702\ufe0f \ua730\u026a\u0274\u1d00\u029f \u1d04\u1d1c\u1d1b\"||\"\"]}{stream.filename::~International[\" \u2702\ufe0f \u026a\u0274\u1d1b\u1d07\u0280\u0274\u1d00\u1d1b\u026a\u1d0f\u0274\u1d00\u029f \u1d04\u1d1c\u1d1b\"||\"\"]}{stream.filename::~Matte[\" \u2702\ufe0f \u1d0f\u1d18\u1d07\u0274 \u1d0d\u1d00\u1d1b\u1d1b\u1d07\"||\"\"]}{stream.filename::~Uncensored[\" \u2702\ufe0f \u1d1c\u0274\u1d04\u1d07\u0274\ua731\u1d0f\u0280\u1d07\u1d05\"||\"\"]}{stream.filename::~Unrated[\" \u2702\ufe0f \u1d1c\u0274\u0280\u1d00\u1d1b\u1d07\u1d05\"||\"\"]}\n",
            "description": "{service.cached::istrue[\"\u26a1 C\u1d00\u1d04\u029c\u1d07\u1d05\"||\"\ud83d\udce1 D\u1d0f\u1d21\u0274\u029f\u1d0f\u1d00\u1d05\"]}  |  {stream.type::exists[\"\ud83c\udf10 {stream.type::smallcaps}  |  \"||\"\"]}{addon.name::exists[\"\u2699\ufe0f {addon.name::smallcaps}  |  \"||\"\"]}{stream.size::>0[\"\ud83d\udce6 {stream.size::sbytes::smallcaps}\"||\"\ud83d\udce6 U\u0274\u1d0b\u0274\u1d0f\u1d21\u0274\"]}{stream.bitrate::exists[\" ({stream.bitrate::sbitrate::replace('MBPS','\u1d0d\u0299\u1d18s')::replace('Mbps','\u1d0d\u0299\u1d18s')::replace('KBPS','\u1d0b\u0299\u1d18s')::replace('Kbps','\u1d0b\u0299\u1d18s')::smallcaps})\"||\"\"]}{stream.seeders::>0[\"  |  \ud83d\udc65 {stream.seeders} S\u1d07\u1d07\u1d05s\"||\"\"]}{tools.newLine}\ud83d\udcfa V\u026a\u1d05\u1d07\u1d0f: {stream.visualTags::exists[\"{stream.visualTags::join(', ')::replace('HDR10+','\u029c\u1d05\u0280\u00b9\u2070\u207a')::replace('HDR10','\u029c\u1d05\u0280\u00b9\u2070')::replace('SDR','SDR \u2713')::replace('HDR','\u26a0 HDR')::replace('DV','\u26a0 DV')::replace('STANDARD','S\u1d1b\u1d00\u0274\u1d05\u1d00\u0280\u1d05')::replace('Standard','S\u1d1b\u1d00\u0274\u1d05\u1d00\u0280\u1d05')::smallcaps}\"||\"SDR \u2713\"]} {stream.encode::exists[\"({stream.encode::replace('HEVC','\u029c\u1d07\u1d20\u1d04')::replace('AVC','\u1d00\u1d20\u1d04')::replace('AV1','\u1d00\u1d201')::smallcaps})\"||\"\"]}{tools.newLine}\ud83d\udd0a A\u1d1c\u1d05\u026a\u1d0f: {stream.audioTags::exists[\"{stream.audioTags::join(', ')::smallcaps}\"||\"S\u1d1b\u1d00\u0274\u1d05\u1d00\u0280\u1d05\"]} {stream.audioChannels::exists[\"({stream.audioChannels::join(', ')})\"||\"\"]}{tools.newLine}\ud83c\udf0d L\u1d00\u0274\u0262: {stream.languages::exists[\"{stream.languages::join(', ')::smallcaps}\"||\"U\u0274\u1d0b\u0274\u1d0f\u1d21\u0274\"]}  |  \ud83d\udcdd S\u1d1c\u0299s: {stream.subtitles::exists[\"{stream.subtitles::join(', ')::smallcaps}\"||\"N\u1d0f\u0274\u1d07\"]}{tools.newLine}{stream.releaseGroup::exists[\"\ud83c\udff7\ufe0f {stream.releaseGroup::smallcaps}\"||\"\ud83c\udff7\ufe0f U\u0274\u1d0b\u0274\u1d0f\u1d21\u0274 G\u0280\u1d0f\u1d1c\u1d18\"]}{stream.regexMatched::exists[\"  |  \ud83d\udee1\ufe0f {stream.regexMatched::smallcaps}\"||\"\"]}{stream.seadexBest::istrue[\"  |  \ud83d\udc51 S\u1d07\u1d00D\u1d07x B\u1d07s\u1d1b\"||\"\"]}\n"
          }
        }
      }
