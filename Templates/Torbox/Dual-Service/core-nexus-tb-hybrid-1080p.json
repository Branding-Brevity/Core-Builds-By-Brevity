    "excludedStreamExpressions": [
      {
        "expression": "/*Hard CAM Kill*/ quality(streams, 'CAM', 'SCR', 'TS', 'TC', 'HC HD-Rip')",
        "enabled": true
      },
      {
        "expression": "/*Hard YouTube Kill*/ type(streams, 'youtube')",
        "enabled": true
      },
      {
        "expression": "/*Hard Bluray & Remux Kill*/ quality(streams, 'BluRay', 'BluRay REMUX')",
        "enabled": true
      },
      {
        "expression": "/*Hard 4K Kill*/ resolution(streams, '2160p', '1440p', 'Unknown')",
        "enabled": true
      },
      {
        "expression": "/*Low SEL Score*/ count(streamExpressionScore(negate(merge(library(streams), seadex(streams)),merge(cached(streams),type(streams,'p2p','http'))),-50))<10?[]:streamExpressionScore(negate(merge(library(streams),seadex(streams)),streams),-1000000,-50)",
        "enabled": true
      },
      {
        "expression": "/*Low Seeders Uncached*/ seeders(uncached(type(streams, 'debrid', 'p2p')), 0, 4)",
        "enabled": true
      },
      {
        "expression": "/*Final Limit (All)*/ merge(count(quality(negate(merge(library(streams), seadex(streams)),merge(cached(streams),type(streams,'p2p','http'))),'WEB-DL','WEBRip')) >20? quality(negate(merge(library(streams), seadex(streams)),streams),'HDRip','HC HD-Rip','DVDRip','HDTV','CAM','TS','TC','SCR'):[])",
        "enabled": true
      }
    ],
    "preferredStreamExpressions": [
      {
        "expression": "/*Boost All Usenet*/ merge(cached(type(streams, 'debrid')), type(streams, 'usenet', 'stremio-usenet'))",
        "enabled": true
      }
    ],
