    "formatter": {
      "id": "tamtaro",
      "definitions": {
        "overrides": {
          "tamtaro": {
            "name": "{service.cached::istrue[\"⚡ Iɴsᴛᴀɴᴛ • \"||\"⏳ Uɴᴄᴀᴄʜᴇᴅ • \"]}{service.shortName::exists[\"{service.shortName}\"||\"\"]}🔹 {stream.resolution::exists[\"{stream.resolution::replace('2160p','🟣 4K UHD')::replace('1440p','🟡 2K')::replace('1080p','🔵 1080ᴘ')::replace('720p','🟢 720ᴘ')::replace('480p','⚫ 480ᴘ')}\"||\"⚪ Uɴᴋɴᴏᴡɴ\"]} • {stream.quality::exists[\"{stream.quality::replace('BluRay REMUX','💎 Rᴇᴍᴜx')::replace('BLURAY REMUX','💎 Rᴇᴍᴜx')::replace('Bluray Remux','💎 Rᴇᴍᴜx')::replace('BluRay Remux','💎 Rᴇᴍᴜx')::replace('BluRay','💿 BʟᴜRᴀʏ')::replace('BLURAY','💿 BʟᴜRᴀʏ')::replace('WEB-DL','🍿 Wᴇʙ-DL')::replace('Web-dl','🍿 Wᴇʙ-DL')::replace('WEBRip','📼 WᴇʙRɪᴘ')::replace('Webrip','📼 WᴇʙRɪᴘ')::smallcaps}\"||\"🔘 Sᴛᴀɴᴅᴀʀᴅ\"]}{stream.audioTags::exists[\"🔹 {stream.audioTags::join(' • ')::replace('Atmos','🎶 Aᴛᴍᴏs')::replace('TrueHD','💎 TʀᴜᴇHD')::replace('DTS-HD MA','🔷 DTS-HD MA')::replace('DTS-X','🎵 DTS-X')::replace('DDP','🎶 DD+')::replace('DD+','🎶 DD+')::replace('DD','🎵 DD')::replace('AAC','🎵 ᴀᴀᴄ')::replace('FLAC','💿 ꜰʟᴀᴄ')::smallcaps}\"||\"\"]}{stream.audioChannels::exists[\" • 🔊 {stream.audioChannels::join('/')}\"||\"\"]}{stream.audioTags::~(?i)(EAC3|DDP|DD\\+)[\"🔹 🔊 JBL Sᴘᴀᴛɪᴀʟ\"||\"\"]}{stream.visualTags::~(?i)(SDR|HDR10)[\"🔹 ☀️ Hɪᴍᴀʟᴀʏᴀ\"||\"\"]}{stream.releaseGroup::~(?i)(epsilon|framestor|qxr|tigole|ntb|flux|d-z0n3|playbd|hifi|don|huno|bmf)[\"🔹 👑 Pʀᴇᴍɪᴜᴍ\"||\"\"]}{stream.editions::exists[\"🔹 🎬 {stream.editions::join(' • ')::smallcaps}\"||\"\"]}{stream.filename::~Boutique[\"🔹 🎬 ʙᴏᴜᴛɪQᴜᴇ\"||\"\"]}{stream.filename::~Despecialized[\"🔹 🌌 ᴅᴇꜱCPEᴄɪᴀʟɪᴢᴇᴅ\"||\"\"]}{stream.filename::~Final.Cut[\"🔹 ✂️ ꜰɪɴᴀʟ ᴄᴜᴛ\"||\"\"]}{stream.filename::~International[\"🔹 🌍 ɪɴᴛᴇʀɴᴀᴛɪᴏɴᴀʟ\"||\"\"]}{stream.filename::~Matte[\"🔹 🌌 ᴏᴘᴇɴ ᴍᴀᴛᴛᴇ\"||\"\"]}{stream.filename::~Uncensored[\"🔹 🩸 ᴜɴᴄᴇɴꜱᴏʀᴇᴅ\"||\"\"]}{stream.filename::~Unrated[\"🔹 🎬 ᴜɴʀᴀᴛᴇᴅ\"||\"\"]}{stream.filename::~IMAX[\"🔹 🎞️ ɪᴍᴀx\"||\"\"]}{stream.filename::~Hybrid[\"🔹 🧬 ʜʏʙʀɪᴅ\"||\"\"]}",
            "description": "🗓️ {stream.age::>0[\"{stream.age} Dᴀʏs\"||\"✨ Nᴇᴡ\"]}{stream.type::exists[\"🔹 ☁️ {stream.type::smallcaps}\"||\"\"]}{addon.name::exists[\"🔹 🧩 {addon.name::smallcaps}\"||\"\"]}{tools.newLine}{stream.bitrate::exists[\"⚡ {stream.bitrate::sbitrate::replace('MBPS','ᴍʙᴘs')::replace('Mbps','ᴍʙᴘs')::replace('KBPS','ᴋʙᴘs')::replace('Kbps','ᴋʙᴘs')::smallcaps}\"||\"⚡ Uɴᴋɴᴏᴡɴ\"]}{stream.size::>0[\"🔹 💾 {stream.size::sbytes::smallcaps}\"||\"🔹 💾 Uɴᴋɴᴏᴡɴ\"]}{stream.seeders::>0[\"🔹 🌱 {stream.seeders} Sᴇᴇᴅᴇʀs\"||\"\"]}{tools.newLine}{tools.newLine}🎞️ Vɪᴅᴇᴏ: {stream.visualTags::exists[\"{stream.visualTags::join('🔹 ')::replace('HDR10+','✨ ʜᴅʀ¹⁰⁺')::replace('HDR10','🌟 ʜᴅʀ¹⁰')::replace('SDR','☀️ SDR')::replace('HDR','🌟 HDR')::replace('DV','✨ DV')::replace('10BIT','🎨 10ʙɪᴛ')::replace('10bit','🎨 10ʙɪᴛ')::replace('STANDARD','Sᴛᴀɴᴅᴀʀᴅ')::replace('Standard','Sᴛᴀɴᴅᴀʀᴅ')::smallcaps}\"||\"☀️ SDR\"]}{stream.encode::exists[\"🔹 ⚙️ {stream.encode::replace('HEVC','ʜᴇᴠᴄ')::replace('AVC','ᴀᴠᴄ')::replace('AV1','ᴀᴠ1')::smallcaps}\"||\"\"]}🔹 🌍 Lᴀɴɢ: {stream.languages::>1[\"ᴇɴɢʟɪsʜ🔹 🗣️ ᴍᴜʟᴛɪ\"||\"\"]}{stream.languages::==1[\"{stream.languages::join('')::smallcaps}\"||\"\"]}{stream.languages::exists[\"\"||\"Uɴᴋɴᴏᴡɴ\"]}{tools.newLine}🎯 Rᴇʟᴇᴀsᴇ: {stream.releaseGroup::exists[\"👑 {stream.releaseGroup::smallcaps}\"||\"👤 Uɴᴋɴᴏᴡɴ Gʀᴏᴜᴘ\"]}{stream.regexMatched::exists[\"🔹 🛡️ {stream.regexMatched::smallcaps}\"||\"\"]}{stream.seadexBest::istrue[\"🔹 🏆 Bᴇsᴛ Rᴇʟᴇᴀsᴇ\"||\"\"]}"
          }
        }
      }
